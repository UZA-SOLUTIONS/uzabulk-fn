# Copy to `.env` or `.env.local` for local dev. For production builds, set these
# in CI or your shell before `npm run build` (Create React App bakes them in).

# API origin only — no path, no trailing slash. Axios uses `${REACT_APP_API_URL}/api/v1`.
# Production (same server, subdomain): https://api.uzabulk.com
# Local backend: http://localhost:1302
REACT_APP_API_URL=https://api.uzabulk.com

# Optional: development | production (used by helpers)
REACT_APP_ENVIORNMENT=production

# Optional: timeout in ms (see src/helpers/apiHelper.js)
# REACT_APP_API_TIMEOUT_MS=120000

# Product detail chat button — WhatsApp (country code + number, e.g. 250788123456)
# REACT_APP_SUPPORT_WHATSAPP=
# REACT_APP_SUPPORT_EMAIL=support@example.com
